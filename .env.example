# ── Background Jobs (Inngest) ───────────────────────────────────────────────
# Required in production. Leave empty for local dev (uses Inngest dev server).
# Get keys at: https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Agent Webhook Bridge (n8n / Make / Zapier) ──────────────────────────────
# Wire each agent to an external workflow tool for live skill execution.
# Leave empty to use built-in handlers or dry-run fallback.
# Pattern: POST webhookUrl receives { actionRef, agentId, skillId, input, workspaceId }
AGENT_MARKETING_WEBHOOK_URL=
AGENT_INVENTOR_WEBHOOK_URL=
AGENT_HERMES_WEBHOOK_URL=
