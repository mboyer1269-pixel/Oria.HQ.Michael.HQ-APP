ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MICHAEL_HQ_OWNER_ID=
MICHAEL_HQ_OWNER_EMAIL=

# ── Dev single-user fallback ────────────────────────────────────────────────
# When MICHAEL_HQ_OWNER_ID is empty, the app uses a local dev single-user
# identity ("local-michael", in-memory storage). DEV / LOCAL ONLY.
# Outside production this fallback is allowed automatically. In production the
# app fail-closes (throws) when no real owner is configured — UNLESS you set
# the flag below to "true" to explicitly allow it (strongly discouraged).
# Leave empty for any real deployment.
ORIA_ALLOW_DEV_USER_FALLBACK=

# ── Document store (dev/test fixture) ───────────────────────────────────────
# db/documents.json is a LOCAL DEV/TEST fixture, not a production datastore.
# In production the file store is fail-closed (ignored). The real path is the
# Supabase `documents` table (db/schema.sql); see
# docs/migrations/documents-file-store-to-db.md.
# BREAK-GLASS / UNSAFE — never set in a normal production deployment. Setting
# this to "true" forces the file store ON in production and logs a loud warning.
ORIA_UNSAFE_ALLOW_FILE_DOCUMENT_STORE_IN_PROD=

# Durable archive directory for the document-processing CLI
# (src/scripts/process-document.ts) when filing "mcl"-classified files.
# REQUIRED for that script: it MOVES files, so there is no temp-dir fallback —
# it fails closed rather than relocate real documents to purgeable storage.
MCL_ARCHIVE_DIR=

CONTACT_NOTIFICATION_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Rate Limiting (Upstash Redis) ───────────────────────────────────────────
# Optional for local/single-instance. When set, the rate limiter uses Upstash
# Redis (atomic sliding-window, multi-instance safe).
# When absent, falls back to in-memory sliding-window (single-instance only).
# REQUIRED in production behind more than one instance: the in-memory fallback
# is per-instance, so limits under-count and the protection weakens. Production
# without these vars logs a one-time [rate-limit] warning (see src/lib/rate-limit.ts).
# Get credentials at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Background Jobs (Inngest) ───────────────────────────────────────────────
# Required in production. Leave empty for local dev (uses Inngest dev server).
# Get keys at: https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Agent Webhook Bridge (n8n / Make / Zapier) ──────────────────────────────
# Wire each agent to an external workflow tool for live skill execution.
# Leave empty to use built-in handlers or dry-run fallback.
# Pattern: POST webhookUrl receives { actionRef, agentId, skillId, input, workspaceId }
AGENT_MARKETING_WEBHOOK_URL=
AGENT_INVENTOR_WEBHOOK_URL=
AGENT_HERMES_WEBHOOK_URL=
AGENT_WEBHOOK_SIGNING_SECRET=

# ── Facebook Page Publisher (Sales Desk publisher agent) ────────────────────
# Official Meta Graph API only — no cookies, no UI bot. When both vars are set,
# the publisher agent auto-publishes vehicle posts to the dealership's Facebook
# PAGE (pages_manage_posts Page access token). Without them, Page posts run in
# local simulation (dev) or stay ready-to-copy. Facebook MARKETPLACE has no
# public listing API: those publications always keep the human final click.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=

# ── n8n Execution Bridge (CEO-approval-gated) ───────────────────────────────
# Single destination for the n8n_webhook_trigger MCP tool. The webhook is fired
# ONLY when the CEO manually approves a queued execution intent — never from the
# automatic green-lane evaluation (humanOnTheLoop is absolute).
# N8N_SECRET is sent as the x-webhook-secret header (in addition to the HMAC
# signature) so n8n can verify the transfer. Leave empty in dev to keep the
# tool inert (it refuses to dispatch without both vars).
N8N_WEBHOOK_URL=
N8N_SECRET=
